{
  "name": "@stbr/solana-glossary",
  "version": "1.0.0",
  "description": "The most comprehensive Solana ecosystem glossary with i18n support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.mjs",
      "require": "./dist/i18n.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/i18n.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "validate": "node scripts/validate.js",
    "stats": "node -e \"const g = require('./dist/index.js'); console.log('Total terms:', g.allTerms.length); console.log('With definitions:', g.allTerms.filter(t => t.definition).length); console.log('Categories:', [...new Set(g.allTerms.map(t => t.category))].length)\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "solana",
    "glossary",
    "web3",
    "blockchain",
    "terminology",
    "dictionary",
    "i18n"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solanabr/solana-dev-kb",
    "directory": "solana-glossary"
  }
}
